# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=your-team-your-project

CONVEX_URL=https://your-team-your-project.convex.cloud

CONVEX_SITE_URL=https://your-team-your-project.convex.site

BETTER_AUTH_URL=http://localhost:4321

# just run: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters
