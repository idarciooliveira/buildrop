# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=your-team-your-project

CONVEX_URL=https://your-team-your-project.convex.cloud

CONVEX_SITE_URL=https://your-team-your-project.convex.site

PUBLIC_CONVEX_SITE_URL=https://your-team-your-project.convex.site

# Better Auth runs on the Convex site URL.
BETTER_AUTH_URL=https://your-team-your-project.convex.site

# Frontend origin used for callbacks and cross-domain auth requests.
APP_ORIGIN=http://localhost:4321
# Additional browser origins allowed to call the auth endpoints.
APP_TRUSTED_ORIGINS=http://127.0.0.1:4321

# just run: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters
