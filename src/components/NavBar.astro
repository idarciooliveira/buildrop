---
import { Download } from "lucide-astro";
---

<header class="shrink-0 border-b border-[var(--color-border-soft)] bg-[var(--color-surface-page)]">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
    <a href="/" class="flex items-center gap-2.5">
      <span class="ds-icon-tile flex h-9 w-9 items-center justify-center">
        <Download
          class="h-5 w-5 text-white"
          aria-hidden="true"
          stroke-width={2.2}
        />
      </span>
      <span class="text-xl font-black tracking-tight text-[var(--color-text-heading)]"
        >BUILDROP</span
      >
    </a>
    <nav class="flex items-center gap-6 text-sm font-medium">
      <a href="#" class="ds-nav-link transition hover:text-[var(--color-brand-700)]">App List</a>
      <a href="#" class="ds-nav-link-active transition hover:text-[var(--color-brand-700)]">Idarcio Filipe</a>
    </nav>
  </div>
</header>
