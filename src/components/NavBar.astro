---
import { Download } from "lucide-astro";
---

<header class="shrink-0 border-b border-slate-200">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
    <a href="/" class="flex items-center gap-2.5">
      <span
        class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-sky-600 to-cyan-400 shadow shadow-cyan-500/25"
      >
        <Download
          class="h-5 w-5 text-white"
          aria-hidden="true"
          stroke-width={2.2}
        />
      </span>
      <span class="text-xl font-black tracking-tight text-sky-900"
        >BUILDROP</span
      >
    </a>
    <nav class="flex items-center gap-6 text-sm font-medium text-slate-500">
      <a href="#" class="transition hover:text-sky-700">App List</a>
      <a href="#" class="transition hover:text-sky-700">Idarcio Filipe</a>
    </nav>
  </div>
</header>
