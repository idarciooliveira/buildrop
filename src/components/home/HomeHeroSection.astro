<section class="relative overflow-hidden px-4 pt-20 pb-24 sm:px-6" id="how-it-works">
  <div
    class="pointer-events-none absolute top-20 left-10 h-64 w-64 rounded-full bg-[#25F45C] opacity-20 blur-[100px]"
  >
  </div>
  <div
    class="pointer-events-none absolute top-40 right-10 h-72 w-72 rounded-full bg-[#502274] opacity-20 blur-[100px]"
  >
  </div>
  <div
    class="pointer-events-none absolute bottom-10 left-1/3 h-80 w-80 rounded-full bg-pink-400 opacity-15 blur-[120px]"
  >
  </div>
  <div class="relative z-10 mx-auto mb-16 max-w-4xl text-center">
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/60 bg-white/50 px-3 py-1 text-xs font-bold tracking-wider text-[#502274] uppercase backdrop-blur-md"
    >
      <span class="h-2 w-2 animate-pulse rounded-full bg-[#25F45C]"></span>
      New: Dark Mode V2.0
    </div>
    <h1
      class="mb-8 text-5xl leading-none font-black tracking-tight text-gray-900 sm:text-6xl md:text-7xl"
    >
      App distribution, <br />
      <span
        class="bg-gradient-to-br from-[#25F45C] to-[#8C52FF] bg-clip-text text-transparent"
        >reimagined.</span
      >
    </h1>
    <p
      class="mx-auto mb-10 max-w-2xl text-xl leading-relaxed font-medium text-gray-600 sm:text-2xl"
    >
      The vibiest way to share IPA & APK files with your team. Drop, share, and
      get feedback faster than ever.
    </p>
    <div class="mx-auto max-w-2xl [perspective:1000px]">
      <div
        class="group relative overflow-hidden rounded-[2.5rem] border border-white/50 bg-white/80 p-3 shadow-2xl transition-transform duration-500 hover:-translate-y-2"
      >
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-br from-[#25F45C]/5 to-[#502274]/5 opacity-0 transition-opacity duration-500 group-hover:opacity-100"
        >
        </div>
        <div
          class="relative z-10 flex h-72 flex-col items-center justify-center gap-6 rounded-[2rem] border-2 border-dashed border-gray-300 bg-gray-50/50 transition-colors group-hover:border-[#25F45C]"
        >
          <div class="relative">
            <div
              class="relative z-10 flex h-24 w-24 items-center justify-center rounded-3xl bg-gradient-to-br from-gray-100 to-white text-gray-400 shadow-lg transition-all duration-300 group-hover:scale-110 group-hover:text-[#25F45C]"
            >
              <span class="material-symbols-outlined text-5xl">cloud_upload</span>
            </div>
          </div>
          <div class="text-center">
            <h3 class="mb-2 text-2xl font-bold text-gray-900">
              Drop your app file here
            </h3>
            <p class="text-base font-medium text-gray-500">
              Support for .ipa and .apk files
            </p>
          </div>
          <button
            class="rounded-full bg-gray-900 px-6 py-2 font-bold text-white shadow-md transition-all hover:bg-[#25F45C] hover:text-gray-900"
            >Browse Files</button
          >
        </div>
      </div>
      <div
        class="mt-6 flex items-center justify-center gap-3 text-sm font-semibold text-gray-500"
      >
        <div
          class="flex items-center gap-1 rounded-full bg-white/50 px-3 py-1 backdrop-blur-sm"
        >
          <span class="material-symbols-outlined text-base">lock</span>
          <span>End-to-end encrypted</span>
        </div>
      </div>
    </div>
  </div>
</section>
