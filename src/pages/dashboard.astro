---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Dashboard - BuildDrop</title>
  </head>
  <body class="min-h-screen bg-[#ECEEF4] font-sans text-gray-900 antialiased">
    <header class="bg-brand-primary text-white">
      <div class="mx-auto flex max-w-[1300px] items-center justify-between px-4 py-3 sm:px-6">
        <div class="flex items-center gap-8">
          <a href="/" class="text-[2rem] leading-none font-black tracking-tight">BuildDrop</a>
          <nav class="hidden items-center gap-2 md:flex">
            <a href="/dashboard" class="rounded-xl bg-white/12 px-4 py-2 text-sm font-semibold">Overview</a>
            <a href="#" class="rounded-xl px-4 py-2 text-sm font-semibold text-white/80 hover:bg-white/10">Builds</a>
            <a href="#" class="rounded-xl px-4 py-2 text-sm font-semibold text-white/80 hover:bg-white/10">Analytics</a>
            <a href="#" class="rounded-xl px-4 py-2 text-sm font-semibold text-white/80 hover:bg-white/10">Billing</a>
          </nav>
        </div>
        <div class="flex items-center gap-3">
          <div class="hidden rounded-xl bg-white/12 px-3 py-1.5 text-right text-xs sm:block">
            <p class="font-semibold text-brand-secondary">3 builds expiring soon</p>
            <p class="text-white/80">Review and extend now</p>
          </div>
          <div class="rounded-xl bg-white/12 px-3 py-1.5 text-sm font-semibold">ifilipe@builddrop.dev</div>
        </div>
      </div>
    </header>

    <main class="mx-auto grid max-w-[1300px] gap-6 px-4 py-6 sm:px-6 lg:grid-cols-[280px_1fr]">
      <aside class="space-y-4">
        <section class="rounded-2xl border border-[#D8DCE8] bg-white p-5 shadow-sm">
          <h2 class="text-3xl leading-tight font-black text-[#1f2937]">Uploads</h2>
          <p class="mt-3 text-sm leading-7 text-gray-600">
            Manage your iOS and Android builds, share install links, track events, and keep active tests alive with expiration extensions.
          </p>
          <a href="#" class="mt-3 inline-block text-sm font-semibold text-brand-primary hover:underline">Read documentation</a>
        </section>
        <section class="rounded-2xl border border-[#D8DCE8] bg-white p-5 shadow-sm">
          <p class="text-sm text-gray-500">Portfolio status</p>
          <ul class="mt-3 space-y-3 text-sm text-gray-700">
            <li class="flex items-center justify-between"><span>Apps with builds</span><span class="font-bold">6</span></li>
            <li class="flex items-center justify-between"><span>Total active builds</span><span class="font-bold">14</span></li>
            <li class="flex items-center justify-between"><span>Total installs</span><span class="font-bold">286</span></li>
            <li class="flex items-center justify-between"><span>Email invites sent</span><span class="font-bold">42</span></li>
          </ul>
        </section>
      </aside>

      <section class="space-y-4">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div class="flex flex-wrap items-center gap-3">
            <button type="button" class="rounded-xl bg-brand-primary px-4 py-2.5 text-sm font-bold text-white shadow-sm">
              + New upload
            </button>
            <input
              type="text"
              placeholder="Search by app name or token"
              class="w-72 rounded-xl border border-[#CCD3E0] bg-white px-4 py-2.5 text-sm outline-none focus:border-brand-primary"
            />
            <button type="button" class="rounded-xl border border-[#CCD3E0] bg-white px-4 py-2.5 text-sm font-semibold text-gray-700">
              Filter
            </button>
          </div>
          <div class="flex gap-2">
            <button type="button" class="rounded-xl border border-[#CCD3E0] bg-white px-4 py-2.5 text-sm font-semibold text-gray-700">Refresh</button>
            <button type="button" class="rounded-xl border border-[#CCD3E0] bg-white px-4 py-2.5 text-sm font-semibold text-gray-700">Options</button>
          </div>
        </div>

        <div class="overflow-hidden rounded-2xl border border-[#D8DCE8] bg-white shadow-sm">
          <table class="w-full min-w-[980px] text-left text-sm">
            <thead class="bg-[#F6F8FC]">
              <tr class="text-xs font-semibold tracking-wide text-gray-500 uppercase">
                <th class="px-5 py-4">Build</th>
                <th class="px-5 py-4">Platform</th>
                <th class="px-5 py-4">Uploaded</th>
                <th class="px-5 py-4">Expiry</th>
                <th class="px-5 py-4">Installs</th>
                <th class="px-5 py-4">Downloads</th>
                <th class="px-5 py-4">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[#E7EBF3]">
              <tr>
                <td class="px-5 py-4">
                  <p class="font-semibold">Client Beta iOS</p>
                  <p class="text-xs text-gray-500">Token: AB3D9KQ2X7LM · Password protected</p>
                </td>
                <td class="px-5 py-4">iOS</td>
                <td class="px-5 py-4 text-gray-600">Feb 24, 2026</td>
                <td class="px-5 py-4">
                  <span class="rounded-full bg-amber-100 px-2.5 py-1 text-xs font-semibold text-amber-700">3 days left</span>
                </td>
                <td class="px-5 py-4">97</td>
                <td class="px-5 py-4">122</td>
                <td class="px-5 py-4">
                  <div class="flex flex-wrap gap-2">
                    <button type="button" class="rounded-lg border border-[#CCD3E0] px-2.5 py-1">Share</button>
                    <button type="button" class="rounded-lg border border-[#CCD3E0] px-2.5 py-1">Email</button>
                    <button type="button" class="rounded-lg border border-[#CCD3E0] px-2.5 py-1">Analytics</button>
                    <button type="button" class="rounded-lg bg-brand-primary px-2.5 py-1 font-semibold text-white">Extend</button>
                  </div>
                </td>
              </tr>
              <tr>
                <td class="px-5 py-4">
                  <p class="font-semibold">Partner Android QA</p>
                  <p class="text-xs text-gray-500">Token: QW8MN2P5L4TZ · Public link</p>
                </td>
                <td class="px-5 py-4">Android</td>
                <td class="px-5 py-4 text-gray-600">Feb 23, 2026</td>
                <td class="px-5 py-4">
                  <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700">6 days left</span>
                </td>
                <td class="px-5 py-4">54</td>
                <td class="px-5 py-4">81</td>
                <td class="px-5 py-4">
                  <div class="flex flex-wrap gap-2">
                    <button type="button" class="rounded-lg border border-[#CCD3E0] px-2.5 py-1">Share</button>
                    <button type="button" class="rounded-lg border border-[#CCD3E0] px-2.5 py-1">QR code</button>
                    <button type="button" class="rounded-lg border border-rose-200 px-2.5 py-1 text-rose-700">Delete</button>
                  </div>
                </td>
              </tr>
              <tr>
                <td class="px-5 py-4">
                  <p class="font-semibold">Internal Staging App</p>
                  <p class="text-xs text-gray-500">Token: H7YB1N4R6VKC · Password protected</p>
                </td>
                <td class="px-5 py-4">iOS + Android</td>
                <td class="px-5 py-4 text-gray-600">Feb 21, 2026</td>
                <td class="px-5 py-4">
                  <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700">5 days left</span>
                </td>
                <td class="px-5 py-4">135</td>
                <td class="px-5 py-4">201</td>
                <td class="px-5 py-4">
                  <div class="flex flex-wrap gap-2">
                    <button type="button" class="rounded-lg border border-[#CCD3E0] px-2.5 py-1">Share</button>
                    <button type="button" class="rounded-lg border border-[#CCD3E0] px-2.5 py-1">Email</button>
                    <button type="button" class="rounded-lg border border-[#CCD3E0] px-2.5 py-1">Analytics</button>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>

          <div class="flex flex-wrap items-center justify-between gap-3 border-t border-[#E7EBF3] bg-[#FAFBFD] px-5 py-3 text-sm text-gray-600">
            <p>Showing 1-3 of 14 builds</p>
            <div class="flex items-center gap-4">
              <p>Registered builds expire in 8 days by default.</p>
              <button type="button" class="rounded-lg border border-[#CCD3E0] bg-white px-3 py-1.5 text-xs font-semibold">View all</button>
            </div>
          </div>
        </div>

        <div class="grid gap-4 lg:grid-cols-3">
          <article class="rounded-2xl border border-[#D8DCE8] bg-white p-4 shadow-sm">
            <h3 class="font-black">Extension pricing</h3>
            <p class="mt-2 text-sm text-gray-600">1 month $1.00 · 6 months $4.99 · 1 year $9.99</p>
          </article>
          <article class="rounded-2xl border border-[#D8DCE8] bg-white p-4 shadow-sm">
            <h3 class="font-black">Upload rules</h3>
            <p class="mt-2 text-sm text-gray-600">Accepted: .ipa, zipped .app, .apk · Max file size: 1 GB.</p>
          </article>
          <article class="rounded-2xl border border-[#D8DCE8] bg-white p-4 shadow-sm">
            <h3 class="font-black">Recent installs</h3>
            <p class="mt-2 text-sm text-gray-600">iPhone 14 Pro, Pixel 8, and iPad Air activity in the last 30 minutes.</p>
          </article>
        </div>
      </section>
    </main>
  </body>
</html>
