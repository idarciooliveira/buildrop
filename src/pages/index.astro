---
import BuildropDropzone from "../components/BuildropDropzone.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="flex h-screen flex-col overflow-hidden bg-white text-slate-950">
    <header class="shrink-0 border-b border-slate-200">
      <div
        class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3"
      >
        <a href="/" class="flex items-center gap-2.5">
          <span
            class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-sky-600 to-cyan-400 shadow shadow-cyan-500/25"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5 text-white"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M12 3v12"></path><path d="m7 10 5 5 5-5"></path><path
                d="M5 21h14"></path>
            </svg>
          </span>
          <span class="text-xl font-black tracking-tight text-sky-900"
            >BUILDROP</span
          >
        </a>
        <nav class="flex items-center gap-6 text-sm font-medium text-slate-500">
          <a href="#" class="transition hover:text-sky-700">App List</a>
        </nav>
      </div>
    </header>

    <div class="flex min-h-0 flex-1 flex-col">
      <section
        class="shrink-0 bg-gradient-to-b from-slate-50 to-white px-6 pb-5 pt-7 text-center"
      >
        <h1
          class="mx-auto max-w-4xl text-2xl font-semibold leading-snug tracking-tight text-sky-900 sm:text-3xl lg:text-4xl"
        >
          Distribute your iOS and Android application and install it over the
          air with Buildrop.
        </h1>
        <p class="mx-auto mt-2 max-w-2xl text-base italic text-slate-400">
          We have made the process easier to send your testing builds.
        </p>
      </section>

      <section class="shrink-0 px-6 pb-4 pt-2">
        <div class="relative mx-auto max-w-4xl">
          <div
            class="pointer-events-none absolute left-[12.5%] right-[12.5%] top-5 hidden h-px bg-slate-200 sm:block"
          >
          </div>
          <div class="grid grid-cols-4 gap-2 text-center">
            <div class="relative">
              <div
                class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-sky-500 to-cyan-400 text-white shadow shadow-cyan-500/25"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M12 17V3"></path><path d="m7 8 5-5 5 5"></path><path
                    d="M5 21h14"></path>
                </svg>
              </div>
              <p class="mt-2 text-sm font-bold text-slate-800">1. Upload</p>
              <p
                class="mt-0.5 hidden text-xs leading-snug text-slate-400 sm:block"
              >
                Upload your IPA or APK file.
              </p>
            </div>
            <div class="relative">
              <div
                class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-sky-500 to-cyan-400 text-white shadow shadow-cyan-500/25"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14"></path><path d="M12 5v14"></path>
                </svg>
              </div>
              <p class="mt-2 text-sm font-bold text-slate-800">2. Submit</p>
              <p
                class="mt-0.5 hidden text-xs leading-snug text-slate-400 sm:block"
              >
                Get the installation link.
              </p>
            </div>
            <div class="relative">
              <div
                class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-sky-500 to-cyan-400 text-white shadow shadow-cyan-500/25"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <circle cx="6" cy="12" r="2"></circle><circle
                    cx="18"
                    cy="6"
                    r="2"></circle><circle cx="18" cy="18" r="2"></circle>
                  <path d="m8 10.5 8-3.5"></path><path d="m8 13.5 8 3.5"></path>
                </svg>
              </div>
              <p class="mt-2 text-sm font-bold text-slate-800">3. Share</p>
              <p
                class="mt-0.5 hidden text-xs leading-snug text-slate-400 sm:block"
              >
                Share the link with testers.
              </p>
            </div>
            <div class="relative">
              <div
                class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-sky-500 to-cyan-400 text-white shadow shadow-cyan-500/25"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="7" y="3" width="10" height="18" rx="2"></rect><path
                    d="M11 18h2"></path>
                </svg>
              </div>
              <p class="mt-2 text-sm font-bold text-slate-800">4. Open</p>
              <p
                class="mt-0.5 hidden text-xs leading-snug text-slate-400 sm:block"
              >
                Install on iOS or Android.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="uploader" class="flex min-h-0 flex-1 flex-col px-6 pb-5">
        <BuildropDropzone />
      </section>
    </div>
  </main>
</Layout>
