---
import BuildropDropzone from "../components/BuildropDropzone.astro";
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import { Download, Plus, Share2, Smartphone } from "lucide-astro";
---

<Layout>
  <main class="ds-page flex h-screen flex-col overflow-hidden">
    <NavBar />

    <div class="flex min-h-0 flex-1 flex-col">
      <section class="ds-hero shrink-0 px-6 pb-5 pt-7 text-center">
        <h1
          class="ds-title mx-auto max-w-4xl text-2xl leading-snug sm:text-3xl lg:text-4xl"
        >
          Distribute your iOS and Android application and install it over the
          air with Buildrop.
        </h1>
        <p class="ds-subtitle mx-auto mt-2 max-w-2xl text-base">
          We have made the process easier to send your testing builds.
        </p>
      </section>

      <section class="shrink-0 px-6 pb-4 pt-2">
        <div class="relative mx-auto max-w-4xl">
          <div
            class="pointer-events-none absolute left-[12.5%] right-[12.5%] top-5 hidden h-px bg-(--color-border-soft) sm:block"
          >
          </div>
          <div class="grid grid-cols-4 gap-2 text-center">
            <div class="relative">
              <div
                class="ds-icon-tile mx-auto flex h-10 w-10 items-center justify-center"
              >
                <Download class="h-5 w-5" aria-hidden="true" stroke-width={2} />
              </div>
              <p class="ds-step-label mt-2 text-sm">1. Upload</p>
              <p
                class="ds-step-copy mt-0.5 hidden text-xs leading-snug sm:block"
              >
                Upload your IPA or APK file.
              </p>
            </div>
            <div class="relative">
              <div
                class="ds-icon-tile mx-auto flex h-10 w-10 items-center justify-center"
              >
                <Plus class="h-5 w-5" aria-hidden="true" stroke-width={2} />
              </div>
              <p class="ds-step-label mt-2 text-sm">2. Submit</p>
              <p
                class="ds-step-copy mt-0.5 hidden text-xs leading-snug sm:block"
              >
                Get the installation link.
              </p>
            </div>
            <div class="relative">
              <div
                class="ds-icon-tile mx-auto flex h-10 w-10 items-center justify-center"
              >
                <Share2 class="h-5 w-5" aria-hidden="true" stroke-width={2} />
              </div>
              <p class="ds-step-label mt-2 text-sm">3. Share</p>
              <p
                class="ds-step-copy mt-0.5 hidden text-xs leading-snug sm:block"
              >
                Share the link with testers.
              </p>
            </div>
            <div class="relative">
              <div
                class="ds-icon-tile mx-auto flex h-10 w-10 items-center justify-center"
              >
                <Smartphone
                  class="h-5 w-5"
                  aria-hidden="true"
                  stroke-width={2}
                />
              </div>
              <p class="ds-step-label mt-2 text-sm">4. Open</p>
              <p
                class="ds-step-copy mt-0.5 hidden text-xs leading-snug sm:block"
              >
                Install on iOS or Android.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="uploader" class="flex min-h-0 flex-1 flex-col px-6 pb-5">
        <BuildropDropzone />
      </section>
    </div>
  </main>
</Layout>
