---
import AuthForm from "../components/AuthForm.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="ds-page min-h-screen">
    <AuthForm
      mode="sign-up"
      title="Sign up"
      submitLabel="Sign up"
      alternateHref="/sign-in"
      alternateLabel="Already have an account? Sign in"
    />
  </main>
</Layout>
